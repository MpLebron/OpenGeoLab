# =====================================================
# Core host configuration.
# Use localhost for local development. Use a LAN IP for network access.
# =====================================================
VITE_HOST_IP=localhost
VITE_API_BASE_URL=http://localhost:3000

# Optional: MapMyVisitors widget id for this OpenGeoLab site.
# Use the value after "d=" from your own MapMyVisitors embed code.
# Leave empty in development to avoid showing demo/public visitor counts.
VITE_MAPMYVISITORS_WIDGET_ID=
