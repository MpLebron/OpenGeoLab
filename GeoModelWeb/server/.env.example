# GitHub OAuth configuration.
# Create an OAuth App in GitHub Developer Settings.
# https://github.com/settings/developers

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth configuration.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT secret. Replace this with a random string for local deployment.
JWT_SECRET=replace-with-a-random-local-secret

# Service configuration.
PORT=3000

# =====================================================
# Core host configuration.
# Use localhost for local development. Use a LAN IP for network access.
# =====================================================
HOST_IP=localhost

# Docker configuration.
DOCKER_HOST=npipe:////./pipe/docker_engine
USER_DATA_DIR=./jupyter-data

# MongoDB configuration.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=opengms_jupyter

# OpenGMS user-system integration.
OPENGMS_USER_SERVER_URL=
OPENGMS_CLIENT_ID=
OPENGMS_CLIENT_SECRET=
OPENGMS_AVATAR_BASE_URL=
OPENGMS_PASSWORD_ENCODING=sha256_md5

# OpenGMS model and data-method service credentials.
OGMS_TOKEN=replace-with-your-opengms-token
API_TOKEN=replace-with-your-opengms-token
OGMS_DEPLOYED_MODEL_QUERY_TOKEN=replace-with-your-deployed-model-query-token
